<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PokeDexMVVM.Views"
    x:Class="PokeDexMVVM.AppShell">

    <TabBar>
        <Tab Title="Pokédex">
            <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Favoritos">
            <ShellContent Route="FavoritosPage" ContentTemplate="{DataTemplate views:FavoritosPage}" />
        </Tab>
        <Tab Title="Equipo">
            <ShellContent Route="EquipoPage" ContentTemplate="{DataTemplate views:EquipoPage}"/>
        </Tab>
    </TabBar>
</Shell>
