<?xml version ="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PokeDexMVVM.ViewModels"
             x:Class="PokeDexMVVM.Views.MainPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="10">

        <Label Grid.Row="0"
               Text="Pokedex"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black"
               Margin="0,20,0,15"/>

        <SearchBar Grid.Row="1"
                   Placeholder="Buscar Pokémon..."
                   Text="{Binding TextoBusqueda}"
                   SearchCommand="{Binding FiltrarPokemonsCommand}"
                   PlaceholderColor="Gray"
                   BackgroundColor="#E2E8F0"
                   TextColor="Black"
                   Margin="10"/>

        <Label Grid.Row="2"
               Text="{Binding MensajeEstado}"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="10"
               TextColor="Black"/>


        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding ListaPokemons}">

            <!-- En teléfono 2 columnas, en escritorio 4. Evita que las cards queden angostas -->
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="{OnIdiom Phone=2, Desktop=4, Default=3}"
                                 VerticalItemSpacing="10"
                                 HorizontalItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10"
                           Margin="5"
                           BorderColor="Gray"
                           CornerRadius="20"
                           BackgroundColor="#E2E8F0"
                           HeightRequest="200">

                        <AbsoluteLayout>

                            <!-- Imagen y nombre: tocar esta zona navega al detalle -->
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 Padding="5"
                                                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                                                 AbsoluteLayout.LayoutFlags="All">

                                <Image Source="{Binding Imagen}"
                                       HeightRequest="120"
                                       Aspect="AspectFit"/>

                                <Label Text="{Binding NombreCapitalizado}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="TailTruncation"
                                       Margin="0,5,0,0"
                                       TextColor="Black"/>

                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPokemonTapped" CommandParameter="{Binding .}"/>
                                </VerticalStackLayout.GestureRecognizers>
                            </VerticalStackLayout>

                            <!-- Ícono de Favorito (arriba derecha) -->
                            <Button Text="{Binding EsFavorito, Converter={StaticResource BoolToBookmarkConverter}}"
                                    FontFamily="MaterialIcons"
                                    FontSize="24"
                                    TextColor="{Binding EsFavorito, Converter={StaticResource BoolToColorConverter}}"
                                    BackgroundColor="Transparent"
                                    Padding="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleFavoritoCommand}"
                                    CommandParameter="{Binding .}"
                                    AbsoluteLayout.LayoutBounds="1,0,40,40"
                                    AbsoluteLayout.LayoutFlags="XProportional"/>

                            <!-- Ícono de Equipo (abajo derecha) -->
                            <Image Source="{Binding EsEnEquipo, Converter={StaticResource BoolToPokeballImageConverter}}"
                                   BackgroundColor="Transparent"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   AbsoluteLayout.LayoutBounds="1,1,36,36"
                                   AbsoluteLayout.LayoutFlags="XProportional,YProportional">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleEquipoCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Image.GestureRecognizers>
                            </Image>

                        </AbsoluteLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>




