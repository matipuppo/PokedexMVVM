<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokeDexMVVM.Views.MapaPage"
             BackgroundColor="White"
             Title="Mapa">

    <!-- Grid principal con 3 filas: encabezado, mapa y lista de pokémons -->
    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Fila 0: Encabezado con título, estado, coordenadas y botón de búsqueda -->
        <VerticalStackLayout Grid.Row="0" Padding="15" Spacing="8">

            <Label Text="Pokémon cerca tuyo"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="Black" HorizontalOptions="Center"/>

            <Label Text="{Binding MensajeEstado}"
                   FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>

            <Label IsVisible="{Binding UbicacionObtenida}"
                   TextColor="#2563EB" FontSize="13" HorizontalOptions="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Tu ubicación: "/>
                        <Span Text="{Binding LatitudUsuario, StringFormat='{0:0.0000}'}"/>
                        <Span Text=", "/>
                        <Span Text="{Binding LongitudUsuario, StringFormat='{0:0.0000}'}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Button Text="Buscar Pokémon cercanos"
                    Command="{Binding BuscarPokemonsCommand}"
                    BackgroundColor="#3B82F6" TextColor="White" CornerRadius="10"/>
        </VerticalStackLayout>

        <!-- Fila 1: Mapa nativo + cartelito propio superpuesto -->
        <Grid Grid.Row="1">

            <!-- Contenedor del mapa (se llena en code-behind solo en Android) -->
            <ContentView x:Name="MapContainer" HeightRequest="250"/>

            <!-- Cartelito propio que se muestra al tocar una tarjeta (oculto por defecto) -->
            <Frame x:Name="CartelitoSeleccion" IsVisible="False"
                   BackgroundColor="White" BorderColor="#CBD5E1" CornerRadius="10"
                   Padding="12,6" HasShadow="True"
                   HorizontalOptions="Center" VerticalOptions="Start" Margin="0,10,0,0">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="CartelitoNombre" FontAttributes="Bold"
                           TextColor="Black" HorizontalOptions="Center"/>
                    <Label x:Name="CartelitoDistancia" FontSize="12"
                           TextColor="#2563EB" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Fila 2: Lista de Pokémon en 2 columnas -->
        <ScrollView Grid.Row="2" Padding="10,5">
            <FlexLayout BindableLayout.ItemsSource="{Binding PokemonsCercanos}"
                        Wrap="Wrap" Direction="Row" AlignItems="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>

                        <!-- Slot exterior: ocupa el 50% del ancho -->
                        <Frame FlexLayout.Basis="50%"
                               Padding="5" HasShadow="False"
                               BorderColor="Transparent" BackgroundColor="Transparent">

                            <!-- Tarjeta visible de cada Pokémon -->
                            <Frame BorderColor="#CBD5E1" BackgroundColor="#E2E8F0"
                                   CornerRadius="12" Padding="10" HasShadow="True">

                                <!-- Al tocar la tarjeta, centra el mapa y muestra el cartelito -->
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPokemonCercanoTapped"
                                                          CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>

                                <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                                    <Image Source="{Binding Imagen}" WidthRequest="70" HeightRequest="70"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding NombreCapitalizado}" FontSize="15" FontAttributes="Bold"
                                           TextColor="Black" HorizontalOptions="Center"/>
                                    <Label Text="{Binding DistanciaTexto}" FontSize="13" TextColor="#2563EB"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Frame>
                        </Frame>

                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>

    </Grid>
</ContentPage>